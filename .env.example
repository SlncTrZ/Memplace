# Qdrant Configuration
QDRANT_URL=http://192.168.1.227:6333
# ⚠️ SECURITY: Never commit real API keys to git!
# Replace with your actual key in .env file (not this file)
QDRANT_API_KEY=your_qdrant_api_key_here

# Ollama Configuration (for embedding)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text:latest

# Optional: Custom Wings Configuration
# Format: JSON string mapping wing names to Qdrant collection names
# Wings starting with "meilin_" will be auto-detected if not specified
# Example:
# WING_COLLECTIONS={"my_wing": "meilin_my_wing", "docs": "meilin_docs"}

# ⚠️ SECURITY NOTES:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Fill in your actual API keys in .env (NOT this file)
# 3. .env is already in .gitignore - it won't be committed
# 4. Never commit .env to git/PR - contains sensitive data
# 5. Use pre-commit hook to prevent accidental commits (scripts/pre_commit_check.py)
