FROM python:3.9-slim

WORKDIR /app

# Copy MemPalace code
COPY . /app

# Install dependencies
RUN pip install mempalace qdrant-client

# Environment variables
ENV QDRANT_URL=http://qdrant:6333
ENV QDRANT_API_KEY=wQ72uGxOv1kpX5ETBo1FEuKeYWf8ytac11cJIcOg
ENV OLLAMA_URL=http://ollama:11434

# Run MCP server
CMD ["python", "-m", "mempalace.mcp_server", "--vector-store", "qdrant", "--host", "0.0.0.0", "--port", "3002"]